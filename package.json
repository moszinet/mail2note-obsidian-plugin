{
	"name": "mail2note",
	"version": "0.1.0",
	"description": "Obsidian community plugin that syncs emails from mail2note into your vault.",
	"keywords": [
		"obsidian-plugin",
		"mail2note",
		"email"
	],
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"author": "Szilveszter Molnar",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/moszinet/mail2note-obsidian-plugin.git"
	},
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.0.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"happy-dom": "^17.4.4",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
